.stat-value{font-family:'DM Mono',monospace;font-size:22px;font-weight:500;color:var(--accent);line-height:1}
.stat-label{font-size:11px;color:var(--text-muted);margin-top:6px;text-transform:uppercase;letter-spacing:.5px}
.stat-unit{font-size:11px;color:var(--text-secondary);font-family:'DM Mono',monospace}
.slope-badge{display:inline-block;padding:2px 8px;border-radius:6px;font-size:11px;font-weight:600;font-family:'DM Mono',monospace}
.slope-green{background:rgba(74,222,128,.15);color:var(--accent)}
.slope-yellow{background:rgba(245,158,11,.15);color:var(--warning)}
