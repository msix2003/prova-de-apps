.btn-icon:hover{background:var(--bg-input);color:var(--text-primary)}
.main-content{padding:12px 16px 100px;max-width:900px;margin:0 auto}
.card{background:var(--bg-secondary);border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:12px;box-shadow:0 2px 12px var(--shadow)}
.card-title{font-size:14px;font-weight:700;color:var(--accent);margin-bottom:12px;display:flex;align-items:center;gap:8px}
.btn{padding:10px 18px;border-radius:12px;border:none;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;display:inline-flex;align-items:center;gap:6px;white-space:nowrap}
.btn-primary{background:linear-gradient(135deg,var(--accent-dim),var(--accent));color:#0a1f15}
